{
  "name": "@workspace/portfolio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "prebuild": "tsx ./scripts/validate-content.ts && tsx ./scripts/validate-hero.ts",
    "build": "rm -rf dist && vite build --config vite.config.ts && vite build --config vite.config.ts --ssr src/entry-server.tsx --outDir dist/server && tsx ./scripts/prerender.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.7",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "framer-motion": "catalog:",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sharp": "^0.35.2",
    "tailwindcss": "catalog:",
    "tsx": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vite": "catalog:",
    "vite-imagetools": "^10.0.1",
    "wouter": "^3.3.5"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8"
  }
}
